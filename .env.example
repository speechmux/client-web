# SpeechMux client-web configuration.
# Copy to .env and fill in values.

# ── Docker host ports ────────────────────────────────────────────────────────
# Host-side port for the FastAPI backend container.
# Change if 8000 is already in use on this machine.
API_HOST_PORT=8000

# Host-side port for the Next.js frontend container.
# Change if 3020 is already in use on this machine.
WEB_HOST_PORT=3020

# ── FastAPI backend ──────────────────────────────────────────────────────────
# WebSocket URL of the SpeechMux Core server.
CORE_WS_URL=ws://localhost:8091/ws/stream

# API key to inject into session start messages sent to Core.
# Leave empty if Core auth is disabled (auth.require_api_key: false).
CORE_API_KEY=

# Bearer token required from browser clients.
# Leave empty to disable client authentication (local dev only).
ACCESS_TOKEN=

# Max concurrent sessions per authenticated user.
MAX_SESSIONS_PER_USER=2

# Comma-separated allowed CORS origins for the FastAPI backend.
# Must match the URL users open in their browser.
CORS_ORIGINS=http://localhost:3020
